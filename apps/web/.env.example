# apps/web required env vars
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WAY Auth proxy mode (use app origin; auth service is reached via Next rewrites)
NEXT_PUBLIC_WAY_AUTH_BASE_URL=http://localhost:3000
WAY_AUTH_BASE_URL=http://localhost:3000
WAY_AUTH_UPSTREAM_URL=https://way-my-auth-service.vercel.app
NEXT_PUBLIC_WAY_AUTH_KEEP_ALIVE_MS=60000

# Vercel deployment:
# - Set these exact keys in Vercel.
# - Use your production URL for NEXT_PUBLIC_SITE_URL.
# - Set WAY_AUTH_BASE_URL and NEXT_PUBLIC_WAY_AUTH_BASE_URL to your app origin.
# - Set WAY_AUTH_UPSTREAM_URL to your deployed auth service origin.
